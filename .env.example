# ─── Postgres (compartilhado com Omni) ──────────────────────────────────────
# Omni roda Postgres embedded em 8432 no processo omni-api. Criamos schema khal_*
# Database de dev — credentials default do omni-pgserve embedded
KHAL_DATABASE_URL=postgresql://postgres@localhost:8432/omni

# ─── Linear (abrir_ticket) ──────────────────────────────────────────────────
# Gerar em: https://linear.app/settings/account/security  → Personal API key
# Formato real: lin_api_<chars>
LINEAR_API_KEY=<your-linear-personal-api-key>
LINEAR_TEAM_ID=ONYX

# ─── Slack (escalar_atendente) ──────────────────────────────────────────────
# Criar em: https://api.slack.com/messaging/webhooks → Incoming Webhook
# Formato real: https://hooks.slack.com/services/T.../B.../<token>
SLACK_WEBHOOK_URL=<your-slack-incoming-webhook-url>

# ─── Omni SDK (proatividade — cron envia msg via Omni REST API) ─────────────
# OMNI_API_KEY vem do output do `omni install` (~/.omni/config.json).
# OMNI_INSTANCE_ID vem do `omni instances list` após `omni instances create`.
OMNI_API_URL=http://localhost:8882
OMNI_API_KEY=<your-omni-api-key>
OMNI_INSTANCE_ID=<your-omni-instance-id>

# ─── App ────────────────────────────────────────────────────────────────────
NODE_ENV=development
LOG_LEVEL=info
