# ─── Postgres (compartilhado com Omni canonical pgserve) ────────────────────
# Omni v2.260619+ usa pgserve canonical em :5432 (database "omni").
# Schema khal.* fica isolado nesse mesmo DB.
KHAL_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/omni

# ─── CX Demo (mini-backend + painel — substitui Linear/Slack) ───────────────
# Backend HTTP local que substitui Linear (tickets) + Slack (handoffs).
# Sobe com: `bun run demo`  (porta 3000)
CX_DEMO_URL=http://localhost:3000
# Token compartilhado entre cx-tools (MCP) e cx-demo (backend). Gerar com:
#   openssl rand -hex 32
CX_DEMO_TOKEN=dev-token-change-me-in-prod
# Senha do painel web. Avaliador usa esta senha em /login.
CX_DEMO_PASSWORD=onyx-demo
# Opcional: segredo do cookie HMAC do painel. Default usa CX_DEMO_TOKEN.
# CX_DEMO_SESSION_SECRET=<random-hex>
# Opcional: URL do NATS pra realtime SSE (default: nats://localhost:4222).
# NATS_URL=nats://localhost:4222

# ─── Omni SDK (proatividade — cron envia msg via Omni REST API) ─────────────
# OMNI_API_KEY vem do output do `omni install` (~/.omni/config.json).
# OMNI_INSTANCE_ID vem do `omni instances list` após `omni instances create`.
OMNI_API_URL=http://localhost:8882
OMNI_API_KEY=<your-omni-api-key>
OMNI_INSTANCE_ID=<your-omni-instance-id>

# ─── App ────────────────────────────────────────────────────────────────────
NODE_ENV=development
LOG_LEVEL=info
